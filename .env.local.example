# Ollama（ローカル LLM）
# 起動: ollama serve
# モデル取得例: ollama pull gemma3:4b
# 推奨: gemma3:4b（軽量・高速）/ gemma3:12b（高精度）/ llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# VOICEVOX（ずんだもん音声合成）
# 起動: docker run --rm -p 50021:50021 voicevox/voicevox_engine:cpu-latest
VOICEVOX_BASE_URL=http://localhost:50021

# キャッシュディレクトリ（省略時は OS の tmpdir）
# 本番環境では専用ディレクトリを指定すること（/tmp は他ユーザーから読める）
# CACHE_DIR=/var/cache/zunda-summarizer
